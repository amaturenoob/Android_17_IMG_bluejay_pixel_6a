	dphy_diags: dphy_diags {
		phandle = <0x2d>;

		emp {
			reg-base = "dphy";
			help = "0: de-emphasis off, 1: -1.6 dB, 2: -3.5 dB, 3 -6 dB";
			diag-name = "emp";
			bit-range = [01 00];
			desc = "De-Emphasis Control Registers for clock and data lanes";
			reg-offset = [02 0c 03 0c 04 0c 05 0c 06 0c];
		};

		res_down {
			reg-base = "dphy";
			help = "0: 43, 1: 46, 2: 49, 3: 52, 4: 56, 5: 60, 7: 73, 8: 30, 9: 31.2,\n10: 32.5, 11: 34, 12: 35.5, 13: 37, 14: 39, 15: 31";
			diag-name = "res_down";
			bit-range = [03 00];
			desc = "High-Speed Driver Down Resistor Control Registers for clock and\ndata lanes";
			reg-offset = [02 08 03 08 04 08 05 08 06 08];
		};

		edge_con_en {
			reg-base = "dphy";
			help = "0: disable, 1: enable";
			diag-name = "edge_con_en";
			bit-range = [08 08];
			desc = "Cap Peaking Enable Registers for clock and data lanes";
			reg-offset = [02 08 03 08 04 08 05 08 06 08];
		};

		edge_con {
			reg-base = "dphy";
			help = "0: Cap-Peaking Off, 1: Low-strength cap-peaking,\n3: Mid-strength cap-peaking, 7: High-strength cap-peaking";
			diag-name = "edge_con";
			bit-range = [0e 0c];
			desc = "Cap Peaking Control Registers for clock and 4 data lanes";
			reg-offset = [02 08 03 08 04 08 05 08 06 08];
		};

		reg_400m {
			reg-base = "dphy-extra";
			help = "0: 380mV, 1: 390mV, 2: 400mV, 3: 410mV, 4: 420mV, 5: 430mV,\n6: 440mV, 7: 450mV";
			diag-name = "reg_400m";
			bit-range = [06 04];
			desc = "Reference voltage-400mV for HS Function control pin";
			reg-offset = [00 08];
		};

		edge_con_dir {
			reg-base = "dphy";
			help = "0: Forward CapPeaking (@slop high),\n1: Backward Cap Peaking (@slop low)";
			diag-name = "edge_con_dir";
			bit-range = [09 09];
			desc = "Cap Peaking Direction Control Registers for clock and data lanes";
			reg-offset = [02 08 03 08 04 08 05 08 06 08];
		};

		hs_prepare {
			reg-base = "dphy";
			help = "This count value is used in High-Speed Transmit operation.";
			diag-name = "hs_prepare";
			bit-range = "\a";
			desc = "THS-PREPARE (D-PHY) Timing Counter Registers for data lanes";
			reg-offset = <0x3340434 0x5340634>;
		};

		clk_prepare {
			reg-base = "dphy";
			help = "This count value is used in High-Speed Transmit operations";
			diag-name = "clk_prepare";
			bit-range = "\a";
			desc = "TCLK-PREPARE Timing Counter Register";
			reg-offset = [02 34];
		};

		res_up {
			reg-base = "dphy";
			help = "0: 43, 1: 46, 2: 49, 3: 52, 4: 56, 5: 60, 7: 73, 8: 30, 9: 31.2,\n10: 32.5, 11: 34, 12: 35.5, 13: 37, 14: 39, 15: 31";
			diag-name = "res_up";
			bit-range = [07 04];
			desc = "High-Speed Driver Up Resistor Control Registers for clock and\ndata lanes";
			reg-offset = [02 08 03 08 04 08 05 08 06 08];
		};
	};

