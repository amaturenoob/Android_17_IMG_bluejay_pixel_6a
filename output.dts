/dts-v1/;

/ {
	#address-cells = <0x02>;
	soc_id = <0x9845001 0x00>;
	model = "GS101 BLUEJAY MP 1.0 based on GS101";
	#size-cells = <0x01>;
	interrupt-parent = <0x01>;
	compatible = "google,GS101 BLUEJAY", "google,GS101";

	dbgdev-pd-g3aa {
		power-domains = <0x24>;
		compatible = "samsung,exynos-pd-dbg";
	};

	watchdog_cl1@10070000 {
		use_multistage_wdt;
		clock-names = "rate_watchdog", "gate_watchdog";
		interrupts = <0x00 0x2fe 0x04>;
		clocks = <0x1c 0x01 0x1c 0x4e7>;
		index = <0x01>;
		timeout-sec = <0x1e>;
		compatible = "google,gs101-cl1-wdt";
		samsung,syscon-phandle = <0x53>;
		reg = <0x00 0x10070000 0x100>;
	};

	gtnr_align_secu_int_mute: gtnr_align-event-info@1 {
		int-reg-bits = <0x00 0x01>;
		irq-reset-reg = <0x00 0xc8>;
		irq-events = <0x20000000 0x20 0x20000000 0x21>;
		irq-src-reg = <0x00 0xc0>;
		irq-mask-reg = <0x00 0xc4>;
		phandle = <0xfb>;
		irq-reg-space = "tnr_align";
	};

	csi_ctx0_fs_int: csi-event-info@16 {
		int-reg-bits = <0x00 0x01 0x02 0x03 0x04 0x05 0x06 0x07 0x08 0x09 0x0a 0x0b 0x0c 0x0d 0x0e 0x0f 0x10 0x11 0x12 0x13 0x14 0x15 0x16 0x17 0x18 0x19 0x1a 0x1b 0x1c 0x1d 0x1e 0x1f>;
		irq-reset-reg = <0x00 0x24>;
		irq-events = <0x20000000 0x200 0x20000000 0x201 0x20000000 0x202 0x20000000 0x203 0x20000000 0x204 0x20000000 0x205 0x20000000 0x206 0x20000000 0x207 0x20000000 0x208 0x20000000 0x209 0x20000000 0x20a 0x20000000 0x20b 0x20000000 0x20c 0x20000000 0x20d 0x20000000 0x20e 0x20000000 0x20f 0x20000000 0x210 0x20000000 0x211 0x20000000 0x212 0x20000000 0x213 0x20000000 0x214 0x20000000 0x215 0x20000000 0x216 0x20000000 0x217 0x20000000 0x218 0x20000000 0x219 0x20000000 0x21a 0x20000000 0x21b 0x20000000 0x21c 0x20000000 0x21d 0x20000000 0x21e 0x20000000 0x21f>;
		irq-src-reg = <0x00 0x24>;
		irq-mask-reg = <0x00 0x20>;
