	tmuctrl_5: TPU@100B0000 {
		polling_delay_on = <0x32>;
		use-pi-thermal;
		i_max = <0x05>;
		polling_delay_off = <0x00>;
		id = <0x05>;
		interrupts = <0x00 0x302 0x04>;
		hardlimit_threshold = <0x62>;
		ect_nouse;
		sustainable_power = <0xc8>;
		tmu_type = <0x03>;
		#thermal-sensor-cells = <0x00>;
		pause_enable;
		resume_threshold = <0x67>;
		compatible = "samsung,gs101-tmu-v2";
		k_po = <0x3c>;
		integral_cutoff = <0x14>;
		k_i = <0x14>;
		tmu_work_affinity = "0-7";
		reg = <0x00 0x100b0000 0x800>;
		pause_threshold = <0x6c>;
		hardlimit_cooling_state = <0xffffffff>;
		phandle = <0x158>;
		k_pu = <0x3c>;
		hardlimit_enable;
		hardlimit_clr_threshold = <0x5d>;
		tmu_name = "TPU";
	};

	cpu0_memlat_cpugrp: cpu0-cpugrp {
		compatible = "arm-memlat-cpugrp";
		phandle = <0x2ac>;
		cpulist = <0x11>;

		cpu0_cpu_mif_latmon: cpu0-cpu-mif-latmon {
			target-dev = <0x140>;
			core-dev-table = <0x493e0 0x66c88 0x8c230 0x854d0 0xb42d0 0xa50a0 0xe30d0 0xce4c8 0x10c110 0xf78f0 0x1243c8 0x14a140 0x144380 0x177bb8 0x186230 0x1a2f20 0x1b82f8 0x1ef1e0 0x1ee240 0x26ae58>;
			cachemiss-ev = <0x2a>;
			compatible = "arm-memlat-mon";
			phandle = <0x2ad>;
			cpulist = <0x11>;
		};
	};

	dbgdev-pd-dns {
		power-domains = <0x21>;
		compatible = "samsung,exynos-pd-dbg";
	};

