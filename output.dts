				phandle = <0x207>;
				capture;
				usefixup;
				no-pcm;

				cpu {
					sound-dai = <0x47 0xc0000005>;
				};

				daifmt {
					dai-format = "i2s";
				};
			};

			dai_fe_ep4_tx: fe_ep4_tx {
				dai-name = "audio_capture3";
				dynamic;
				id = <0x40000003>;
				stream-name = "EP4 capture";
				phandle = <0x1ec>;
				capture;

				platform {

					votx {
						of_drv = <0x49>;
					};
				};

				cpu {
					sound-dai = <0x47 0x40000003>;
				};
			};

