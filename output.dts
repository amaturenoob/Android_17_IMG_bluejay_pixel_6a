		aoc-card-name = "google,aoc-snd-card";
		compatible = "google-aoc-snd-card";
		phandle = <0x1e0>;

		clks {

			sys {

				sys@cs40l26_codec {
					srcid = <0x00>;
					in_mul = <0x01>;
					id = <0x00>;
