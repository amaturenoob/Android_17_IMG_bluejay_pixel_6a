	ipp_fro_ctx2_int1: ipp_fro-event-info@11 {
		int-reg-bits = <0x00 0x01 0x02 0x03 0x04 0x05 0x06 0x07>;
		irq-reset-reg = <0x00 0x3dc8>;
		irq-events = <0x20000000 0x160 0x20000000 0x161 0x20000000 0x162 0x20000000 0x163 0x20000000 0x164 0x20000000 0x165 0x20000000 0x166 0x20000000 0x167>;
