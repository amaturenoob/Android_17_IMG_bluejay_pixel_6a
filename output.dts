	spi_5: spi@10940000 {
		pinctrl-names = "default";
		#address-cells = <0x01>;
		pinctrl-0 = <0x8c 0x1b7>;
		clock-names = "ipclk_spi", "gate_spi_clk";
		interrupts = <0x00 0x27f 0x04>;
		clocks = <0x1c 0x535 0x1c 0x51a>;
		#size-cells = <0x00>;
		dma-names = "tx", "rx";
		compatible = "samsung,exynos-spi";
		status = "okay";
		samsung,spi-fifosize = <0x40>;
		samsung,usi-phandle = <0x6a>;
		swap-mode = <0x01>;
		reg = <0x00 0x10940000 0x1000>;
		phandle = <0x231>;
		dmas = <0x298 0x0a 0x298 0x0b>;
		samsung,usi-offset = <0x10>;
		dma-mode;

		bcm4775@0 {
			host-req-gpios = <0x17b 0x04 0x00>;
			pinctrl-names = "default";
			pinctrl-0 = <0x2f2 0x2f3 0x2f4 0x2f5>;
			mcu-req-gpios = <0x193 0x01 0x00>;
			spi-max-frequency = <0x18cba80>;
			spi-cpol;
			compatible = "ssp-spi,bcm4775";
			spi-cpha;
			reg = <0x00>;
			mcu-resp-gpios = <0x2e 0x00 0x00>;
			nstandby-gpios = <0x2e 0x02 0x01>;

			controller-data {
				samsung,spi-feedback-delay = <0x01>;
				samsung,spi-chip-select-mode = <0x00>;
			};
		};
	};

	mct@10050000 {
		clock-names = "fin_pll", "mct";
		interrupts = <0x00 0x01 0x02 0x03 0x04 0x05 0x06 0x07 0x08 0x09 0x0a 0x0b>;
		clocks = <0x1c 0x01 0x1c 0x4e4>;
		interrupt-parent = <0x13b>;
		compatible = "samsung,exynos4210-mct";
		#interrupt-cells = <0x01>;
		reg = <0x00 0x10050000 0x800>;
		interrupt-controller;

		mct_map: mct-map {
			#address-cells = <0x00>;
			interrupt-map = <0x00 0x01 0x00 0x2f1 0x04 0x01 0x01 0x00 0x2f2 0x04 0x02 0x01 0x00 0x2f3 0x04 0x03 0x01 0x00 0x2f4 0x04 0x04 0x01 0x00 0x2f5 0x04 0x05 0x01 0x00 0x2f6 0x04 0x06 0x01 0x00 0x2f7 0x04 0x07 0x01 0x00 0x2f8 0x04 0x08 0x01 0x00 0x2f9 0x04 0x09 0x01 0x00 0x2fa 0x04 0x0a 0x01 0x00 0x2fb 0x04 0x0b 0x01 0x00 0x2fc 0x04>;
			#size-cells = <0x00>;
			#interrupt-cells = <0x01>;
			phandle = <0x13b>;
		};
	};

