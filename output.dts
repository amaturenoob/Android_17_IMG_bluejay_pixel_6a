	funnel0: funnel@25007000 {
		arm,primecell-periphid = <0xbb908>;
		clock-names = "apb_pclk";
		reg-names = "funnel-base";
		clocks = <0x1c 0x4e9>;
		coresight-name = "coresight-funnel0";
		compatible = "arm,primecell";
		reg = <0x00 0x25007000 0x1000>;
		phandle = <0x268>;

		in-ports {
			#address-cells = <0x01>;
			#size-cells = <0x00>;

			port@0 {
				reg = <0x00>;

				funnel0_in_port0: endpoint {
					remote-endpoint = <0x129>;
					phandle = <0x120>;
				};
			};

			port@3 {
				reg = <0x03>;

				funnel0_in_port3: endpoint {
					remote-endpoint = <0x12c>;
					phandle = <0x127>;
				};
			};

			port@1 {
				reg = <0x01>;

				funnel0_in_port1: endpoint {
					remote-endpoint = <0x12a>;
					phandle = <0x121>;
				};
			};

			port@2 {
				reg = <0x02>;

				funnel0_in_port2: endpoint {
					remote-endpoint = <0x12b>;
					phandle = <0x126>;
				};
			};
		};

		out-ports {

			port {

				funnel0_out_port: endpoint {
					remote-endpoint = <0x128>;
					phandle = <0x135>;
				};
			};
		};
	};

