	s2mpu_bo: s2mpu@1CA60000 {
		interrupts = <0x00 0x78 0x04>;
		compatible = "google,s2mpu";
		power-domain-id = <0x1ca10204>;
		reg = <0x00 0x1ca60000 0x10000>;
		phandle = <0x270>;
	};

	csi_ctx2_fe_int: csi-event-info@26 {
		int-reg-bits = <0x00 0x01 0x02 0x03 0x04 0x05 0x06 0x07 0x08 0x09 0x0a 0x0b 0x0c 0x0d 0x0e 0x0f 0x10 0x11 0x12 0x13 0x14 0x15 0x16 0x17 0x18 0x19 0x1a 0x1b 0x1c 0x1d 0x1e 0x1f>;
		irq-reset-reg = <0x00 0x2c>;
		irq-events = <0x20000000 0x340 0x20000000 0x341 0x20000000 0x342 0x20000000 0x343 0x20000000 0x344 0x20000000 0x345 0x20000000 0x346 0x20000000 0x347 0x20000000 0x348 0x20000000 0x349 0x20000000 0x34a 0x20000000 0x34b 0x20000000 0x34c 0x20000000 0x34d 0x20000000 0x34e 0x20000000 0x34f 0x20000000 0x350 0x20000000 0x351 0x20000000 0x352 0x20000000 0x353 0x20000000 0x354 0x20000000 0x355 0x20000000 0x356 0x20000000 0x357 0x20000000 0x358 0x20000000 0x359 0x20000000 0x35a 0x20000000 0x35b 0x20000000 0x35c 0x20000000 0x35d 0x20000000 0x35e 0x20000000 0x35f>;
		irq-src-reg = <0x00 0x2c>;
		irq-mask-reg = <0x00 0x28>;
		phandle = <0xb8>;
		irq-reg-space = "csis-link2";
	};

	s2mpu_mfc0: s2mpu@1C890000 {
		interrupts = <0x00 0x23d 0x04>;
		compatible = "google,s2mpu";
		power-domain-id = <0x1c810204>;
		reg = <0x00 0x1c890000 0x10000>;
		phandle = <0x289>;
	};

	sysmmu_g2d0: sysmmu@1C660000 {
		power-domains = <0x23>;
		sysmmu,secure-irq;
		interrupts = <0x00 0x193 0x04 0x00 0x195 0x04>;
		sysmmu,secure_base = <0x1c670000>;
		qos = <0x0f>;
		#iommu-cells = <0x00>;
		compatible = "samsung,sysmmu-v8";
		reg = <0x00 0x1c660000 0x10000>;
		phandle = <0x149>;
		sysmmu,default_tlb = <0xaa>;
		port-name = "G2D0";
	};

	pd_itp: pd-itp@17462680 {
		need_smc = <0x1b410204>;
		#power-domain-cells = <0x00>;
		cmu_id = <0x1b400000>;
		compatible = "samsung,exynos-pd";
		status = "okay";
		reg = <0x00 0x17462680 0x20>;
		phandle = <0x5b>;
		cal_id = <0xb1380013>;
	};

	spi_12: spi@10D50000 {
		pinctrl-names = "default";
		#address-cells = <0x01>;
		pinctrl-0 = <0x94>;
		clock-names = "ipclk_spi", "gate_spi_clk";
		interrupts = <0x00 0x28f 0x04>;
		clocks = <0x1c 0x586 0x1c 0x57d>;
		#size-cells = <0x00>;
		dma-names = "tx", "rx";
		compatible = "samsung,exynos-spi";
		status = "disabled";
		samsung,spi-fifosize = <0x40>;
		samsung,usi-phandle = <0x7f>;
		swap-mode;
		reg = <0x00 0x10d50000 0x1000>;
		phandle = <0x23a>;
		samsung,usi-offset = <0x10>;
	};

	lwis_slc: lwis_slc@0 {
		pt_size = <0x200 0x400 0x400 0x400 0x600 0x600 0x600 0x800 0x800>;
		pt_id = "CAMERA2WAY", "CAMERA4WAY0", "CAMERA4WAY1", "CAMERA4WAY2", "CAMERA6WAY0", "CAMERA6WAY1", "CAMERA6WAY2", "CAMERA8WAY0", "CAMERA8WAY1";
		node-name = "slc";
		compatible = "google,lwis-slc-device";
		phandle = <0x25d>;
	};

	ext_24_5m: ext_24_5m {
		clock-output-names = "ext-24_5m";
		#clock-cells = <0x00>;
		clock-frequency = <0x1770000>;
		compatible = "fixed-clock";
		phandle = <0x294>;
	};

	pd_bo: pd-bo@17462880 {
		need_smc = <0x1ca10204>;
		#power-domain-cells = <0x00>;
		cmu_id = <0x1ca00000>;
		compatible = "samsung,exynos-pd";
		status = "okay";
		reg = <0x00 0x17462880 0x20>;
		phandle = <0x10>;
		cal_id = <0xb1380017>;
	};
};
