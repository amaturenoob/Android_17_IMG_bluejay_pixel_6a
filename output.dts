	cpus {
		#address-cells = <0x02>;
		#size-cells = <0x00>;

		cpu3: cpu@300 {
			capacity-dmips-mhz = <0xfa>;
			cpu-idle-states = <0x19>;
			device_type = "cpu";
			compatible = "arm,armv8";
			dynamic-power-coefficient = <0x46>;
			reg = <0x00 0x300>;
			enable-method = "psci";
			phandle = <0x14>;
		};

		cpu6: cpu@600 {
			capacity-dmips-mhz = <0x400>;
			cpu-idle-states = <0x1b>;
			device_type = "cpu";
			compatible = "arm,armv8";
			dynamic-power-coefficient = <0x28a>;
			reg = <0x00 0x600>;
			enable-method = "psci";
			phandle = <0x17>;
		};

		idle-states {
			entry-method = "arm,psci";

			ANANKE_CPU_SLEEP: ananke-cpu-sleep {
				entry-latency-us = <0x46>;
				idle-state-name = "c2";
				exit-latency-us = <0xa0>;
				arm,psci-suspend-param = <0x10000>;
				compatible = "arm,idle-state";
				status = "okay";
				phandle = <0x19>;
				min-residency-us = <0x7d0>;
			};

			ENYO_CPU_SLEEP: enyo-cpu-sleep {
				entry-latency-us = <0x96>;
				idle-state-name = "c2";
				exit-latency-us = <0xbe>;
				arm,psci-suspend-param = <0x10000>;
				compatible = "arm,idle-state";
				status = "okay";
				phandle = <0x1a>;
				min-residency-us = <0x9c4>;
			};

			HERA_CPU_SLEEP: hera-cpu-sleep {
				entry-latency-us = <0xeb>;
				idle-state-name = "c2";
				exit-latency-us = <0xdc>;
				arm,psci-suspend-param = <0x10000>;
				compatible = "arm,idle-state";
				status = "okay";
				phandle = <0x1b>;
				min-residency-us = <0xdac>;
			};
		};

