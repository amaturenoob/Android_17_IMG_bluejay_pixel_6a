				dai-name = "audio_capture0";
				dynamic;
				id = <0x40000000>;
				stream-name = "EP1 capture";
				phandle = <0x1e9>;
				capture;

				platform {

					tx1 {
						of_drv = <0x48>;
					};
				};

				cpu {
					sound-dai = <0x47 0x40000000>;
				};
			};

			dai_fe_ep7_rx: fe_ep7_rx {
				dai-name = "audio_playback6";
				dynamic;
				playback;
				id = <0x06>;
				stream-name = "EP7 playback";
				phandle = <0x1e7>;

				platform {

					rx1 {
						of_drv = <0x4a>;
					};
				};

