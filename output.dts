			phandle = <0x12>;
		};

		cpu4: cpu@400 {
			capacity-dmips-mhz = <0x26c>;
			cpu-idle-states = <0x1a>;
			device_type = "cpu";
			compatible = "arm,armv8";
			dynamic-power-coefficient = <0x11c>;
			reg = <0x00 0x400>;
			enable-method = "psci";
			phandle = <0x15>;
		};

		cpu7: cpu@700 {
			capacity-dmips-mhz = <0x400>;
			cpu-idle-states = <0x1b>;
			device_type = "cpu";
			compatible = "arm,armv8";
			dynamic-power-coefficient = <0x28a>;
			reg = <0x00 0x700>;
			enable-method = "psci";
			phandle = <0x18>;
		};
	};

	aoc_incall_ep: aoc_incall_drv {
		compatible = "google-aoc-snd-incall";
		phandle = <0x4d>;
	};

	pd_dpu: pd-dpu@17462200 {
		power-domains = <0x5a>;
		skip-idle-ip;
		need_smc = <0x1c010204>;
		#power-domain-cells = <0x00>;
		cmu_id = <0x1c000000>;
		compatible = "samsung,exynos-pd";
		status = "okay";
		reg = <0x00 0x17462200 0x20>;
		phandle = <0x22>;
		cal_id = <0xb138000a>;
	};

