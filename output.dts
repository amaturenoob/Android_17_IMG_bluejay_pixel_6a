		samsung,spi-fifosize = <0x40>;
		samsung,usi-phandle = <0x6a>;
		swap-mode;
		reg = <0x00 0x10930000 0x1000>;
		phandle = <0x230>;
		samsung,usi-offset = <0x0c>;
	};

